# ── DATABASE ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/almeja_azul?schema=public"

# ── AUTHENTICATION ────────────────────────────────────────────────────────────
# Random secret, minimum 32 characters
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-at-least-32-char-random-secret"

# Initial admin credentials (used by db:seed to create the first admin user)
ADMIN_EMAIL="admin@almejaazul.com"
ADMIN_INITIAL_PASSWORD="change-me-on-first-login"

# ── TRANSACTIONAL EMAIL (Resend) ─────────────────────────────────────────────
# Sends a branded confirmation to the guest and a plain notification to the
# owner whenever an inquiry is submitted. Leave RESEND_API_KEY blank to disable
# all transactional email.
#
# Verify your sending domain in the Resend dashboard before going live.
RESEND_API_KEY=""
EMAIL_FROM="Almeja Azul <hello@almejaazul.com>"
EMAIL_OWNER_NOTIFICATION="ben@thegray.space"

# ── MEDIA STORAGE (optional) ─────────────────────────────────────────────────
# Defaults to local /public/uploads if not set
# Supported: local | s3 | cloudinary | vercel-blob | supabase
MEDIA_STORAGE_PROVIDER="local"
MEDIA_STORAGE_KEY=""
MEDIA_STORAGE_SECRET=""
MEDIA_BUCKET=""
MEDIA_CLOUDINARY_CLOUD_NAME=""

# ── NEXT.JS ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Canonical production site URL. Used by metadata (OG tags, sitemap),
# absolute links in transactional emails, etc. No trailing slash.
# In Vercel, set this to the production apex domain.
NEXT_PUBLIC_SITE_URL="https://almejaazul.com"

# ── ANALYTICS (GTM + Meta) ───────────────────────────────────────────────────
# The site loads a single Google Tag Manager container in <head>. GA4 and Meta
# Pixel are added as TAGS inside that GTM container (configured in the GTM web
# UI), not in code. See docs/runbooks/GTM_SETUP.md.
#
# GTM is no-op unless NODE_ENV=production AND NEXT_PUBLIC_GTM_ID is set.
NEXT_PUBLIC_GTM_ID="GTM-XXXXXX"

# Meta Conversions API (server-side). Sends a Lead event to Meta whenever an
# inquiry is submitted. Pixel-side and CAPI-side events are deduped by event_id.
# Generate the access token in Events Manager → Settings → Conversions API.
META_PIXEL_ID=""
META_CAPI_ACCESS_TOKEN=""
# Optional. Set while testing — events tagged with this code show up under
# Events Manager → Test Events instead of going to production.
META_CAPI_TEST_EVENT_CODE=""

# ── PRE-LAUNCH PASSWORD GATE ─────────────────────────────────────────────────
# Simple shared password that blocks public pages while the site is in
# pre-launch. Set both values to enable; leave SITE_PASSWORD blank to
# disable the gate entirely (public site becomes accessible to anyone).
# SITE_GATE_SECRET must be a separate >=32-char random string (NOT the
# same value as AUTH_SECRET — the gate cookie is unrelated to admin auth).
SITE_PASSWORD=""
SITE_GATE_SECRET="replace-with-at-least-32-char-random-secret"
