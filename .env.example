# ── DATABASE ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/almeja_azul?schema=public"

# ── AUTHENTICATION ────────────────────────────────────────────────────────────
# Random secret, minimum 32 characters
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-at-least-32-char-random-secret"

# Initial admin credentials (used by db:seed to create the first admin user)
ADMIN_EMAIL="admin@almejaazul.com"
ADMIN_INITIAL_PASSWORD="change-me-on-first-login"

# ── EMAIL NOTIFICATIONS (optional) ───────────────────────────────────────────
# Leave blank to disable email notifications for new inquiries
EMAIL_PROVIDER_API_KEY=""
EMAIL_FROM=""
INQUIRY_NOTIFY_TO=""

# --- PHONE ALERTS (optional) -------------------------------------------------
# Leave blank to disable each channel independently
GOOGLE_CHAT_WEBHOOK_URL=""             # optional, from Google Chat space settings
SEMAPHORE_API_KEY=""                   # optional
SEMAPHORE_ALERT_RECIPIENT=""           # optional, e.g., 09993088800

# ── MEDIA STORAGE (optional) ─────────────────────────────────────────────────
# Defaults to local /public/uploads if not set
# Supported: local | s3 | cloudinary | vercel-blob | supabase
MEDIA_STORAGE_PROVIDER="local"
MEDIA_STORAGE_KEY=""
MEDIA_STORAGE_SECRET=""
MEDIA_BUCKET=""
MEDIA_CLOUDINARY_CLOUD_NAME=""

# ── NEXT.JS ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Canonical production site URL. Used by metadata (OG tags, sitemap),
# absolute links in transactional emails, etc. No trailing slash.
# In Vercel, set this to the production apex domain.
NEXT_PUBLIC_SITE_URL="https://almejaazul.com"

# ── PRE-LAUNCH PASSWORD GATE ─────────────────────────────────────────────────
# Simple shared password that blocks public pages while the site is in
# pre-launch. Set both values to enable; leave SITE_PASSWORD blank to
# disable the gate entirely (public site becomes accessible to anyone).
# SITE_GATE_SECRET must be a separate >=32-char random string (NOT the
# same value as AUTH_SECRET — the gate cookie is unrelated to admin auth).
SITE_PASSWORD=""
SITE_GATE_SECRET="replace-with-at-least-32-char-random-secret"
